{
  "name": "context-gc",
  "version": "0.1.9",
  "description": "A local-first, reversible context control plane for Codex.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procloudkim/OpenAI-Build-Week-ContextGC.git"
  },
  "bugs": {
    "url": "https://github.com/procloudkim/OpenAI-Build-Week-ContextGC/issues"
  },
  "homepage": "https://github.com/procloudkim/OpenAI-Build-Week-ContextGC#readme",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "contextgc": "./dist/src/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "npm run build && npm run bundle:mcp && npm run bundle:cli && npm run normalize:bundles",
    "bundle:mcp": "esbuild dist/src/mcp/server.js --bundle --platform=node --target=node22 --format=esm --banner:js=\"// Third-party license notices: ../THIRD_PARTY_NOTICES.md\" --outfile=scripts/mcp-server.bundle.mjs",
    "bundle:cli": "esbuild dist/src/cli/main.js --bundle --platform=node --target=node22 --format=esm --banner:js=\"// Third-party license notices: ../THIRD_PARTY_NOTICES.md\" --outfile=scripts/contextgc.bundle.mjs",
    "normalize:bundles": "node scripts/normalize-bundles.mjs",
    "stage:plugin": "npm run bundle && node scripts/stage-plugin.mjs",
    "check": "npm run build && npm test",
    "test": "node --test \"dist/tests/**/*.test.js\"",
    "benchmark": "node dist/src/eval/run-benchmark.js && node scripts/sync-site-receipts.mjs",
    "contextgc": "node dist/src/cli/main.js",
    "mcp": "node dist/src/mcp/server.js",
    "smoke:bundles": "node scripts/smoke-bundles.mjs",
    "site:build": "npm --prefix site run build",
    "site:verify": "npm --prefix site run lint && npm --prefix site test",
    "verify": "npm run check && npm run benchmark && npm run stage:plugin && npm run smoke:bundles && npm run site:verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.4",
    "esbuild": "0.28.1",
    "typescript": "5.9.3"
  }
}
